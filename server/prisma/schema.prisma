datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id           String        @id @default(uuid())
  email        String        @unique
  username     String        @unique
  passwordHash String
  avatar       String?
  createdAt    DateTime      @default(now())
  
  // Game statistics
  xp           Int           @default(0)
  level        Int           @default(1)
  wins         Int           @default(0)
  losses       Int           @default(0)
  draws        Int           @default(0)

  // Relations
  matchesAsPlayer1 Match[]   @relation("Player1Matches")
  matchesAsPlayer2 Match[]   @relation("Player2Matches")
  matchesWon       Match[]   @relation("WinnerMatches")
}

model Match {
  id         String     @id @default(uuid())
  gameType   String     // "chess", "snakesladders", "connectfour", etc.
  status     String     // "COMPLETED", "ABANDONED"
  
  // Players
  player1Id  String
  player1    User       @relation("Player1Matches", fields: [player1Id], references: [id])
  player2Id  String
  player2    User       @relation("Player2Matches", fields: [player2Id], references: [id])
  
  // Outcome
  winnerId   String?
  winner     User?      @relation("WinnerMatches", fields: [winnerId], references: [id])
  
  startedAt  DateTime   @default(now())
  endedAt    DateTime?
  
  // Move log (saved as JSON string for replays or audits)
  movesJson  String?
}
